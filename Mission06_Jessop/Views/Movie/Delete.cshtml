@model Mission06_Jessop.Models.Movie
@{
    ViewData["Title"] = "Delete Movie";
}

<div class="container mt-4">
    <h1 class="mb-4 text-danger">Delete Movie</h1>
    <p class="lead">Are you sure you want to delete this movie?</p>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@Model.Title</h5>
            <p class="card-text">
                <strong>Category:</strong> @(Model.Category ?? "-")<br />
                <strong>Year:</strong> @Model.Year<br />
                <strong>Director:</strong> @(Model.Director ?? "-")<br />
                <strong>Rating:</strong> @(Model.Rating ?? "-")<br />
                <strong>Copied to Plex:</strong> @(Model.CopiedToPlex ? "Yes" : "No")
            </p>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="MovieId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="MovieList" class="btn btn-secondary">Cancel</a>
    </form>
</div>
