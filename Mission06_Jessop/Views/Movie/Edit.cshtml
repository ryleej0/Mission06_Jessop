@model Mission06_Jessop.Models.Movie
@{
    ViewData["Title"] = "Edit Movie";
}

<div class="container mt-4">
    <h1 class="mb-4">Edit Movie</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="MovieId" />
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Category" class="form-label">Category</label>
            <input asp-for="Category" class="form-control" />
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Year" class="form-label">Year <span class="text-danger">*</span></label>
            <input asp-for="Year" class="form-control" type="number" min="1888" max="2100" />
            <span asp-validation-for="Year" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Director" class="form-label">Director</label>
            <input asp-for="Director" class="form-control" />
            <span asp-validation-for="Director" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Rating" class="form-label">Rating</label>
            <select asp-for="Rating" class="form-select">
                <option value="G">G</option>
                <option value="PG">PG</option>
                <option value="PG-13">PG-13</option>
                <option value="R">R</option>
            </select>
            <span asp-validation-for="Rating" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <div class="form-check">
                <input asp-for="Edited" class="form-check-input" type="checkbox" />
                <label asp-for="Edited" class="form-check-label">Edited <span class="text-danger">*</span></label>
            </div>
        </div>

        <div class="mb-3">
            <div class="form-check">
                <input asp-for="CopiedToPlex" class="form-check-input" type="checkbox" />
                <label asp-for="CopiedToPlex" class="form-check-label">Copied to Plex <span class="text-danger">*</span></label>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="LentTo" class="form-label">Lent To</label>
            <input asp-for="LentTo" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label">Notes</label>
            <input asp-for="Notes" class="form-control" maxlength="25" />
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="MovieList" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
